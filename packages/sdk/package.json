{
  "name": "@agentmd-dev/sdk",
  "version": "0.1.1",
  "description": "AgentMD SDK — programmatic API for integrations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iedayan/agentmd.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "agents.md",
    "agents-md",
    "ai-agents",
    "sdk",
    "integration"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "homepage": "https://agentmd.online",
  "bugs": {
    "url": "https://github.com/iedayan/agentmd/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/iedayan/agentmd"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentmd-dev/core": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
