{
  "name": "agentmd",
  "version": "0.1.0",
  "description": "The official AgentMD extension. Real-time validation, templates, and agent-readiness scoring for AGENTS.md files.",
  "displayName": "AgentMD",
  "publisher": "agentmd",
  "repository": {
    "type": "git",
    "url": "https://github.com/iedayan/agentmd.git",
    "directory": "packages/agentmd-vscode"
  },
  "author": {
    "name": "AgentMD"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "preview": true,
  "qna": "marketplace",
  "keywords": [
    "agentmd",
    "ai",
    "llm",
    "agents.md",
    "cursor",
    "copilot",
    "cline",
    "linter"
  ],
  "bugs": {
    "url": "https://github.com/iedayan/agentmd/issues"
  },
  "homepage": "https://agentmd.online",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "workspaceContains:**/AGENTS.md"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "agentmd",
        "aliases": [
          "AGENTS.md",
          "agentmd"
        ],
        "extensions": [
          ".agents.md"
        ],
        "filenamePatterns": [
          "**/AGENTS.md"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "agentmd.validate",
        "title": "AgentMD: Validate AGENTS.md"
      },
      {
        "command": "agentmd.showScore",
        "title": "AgentMD: Show Score Breakdown"
      },
      {
        "command": "agentmd.createTemplate",
        "title": "AgentMD: Create from Template"
      },
      {
        "command": "agentmd.executeDryRun",
        "title": "AgentMD: Dry Run Execution"
      }
    ],
    "keybindings": [
      {
        "command": "agentmd.validate",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "agentmd.showScore",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ],
    "configuration": {
      "title": "AgentMD",
      "properties": {
        "agentmd.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time diagnostics for AGENTS.md files"
        },
        "agentmd.diagnostics.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay before validation (100-2000ms)"
        },
        "agentmd.score.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show agent-readiness score in status bar"
        },
        "agentmd.autoValidate": {
          "type": "boolean",
          "default": true,
          "description": "Auto-validate AGENTS.md on save"
        },
        "agentmd.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show AgentMD status in status bar"
        },
        "agentmd.enableRealTime": {
          "type": "boolean",
          "default": true,
          "description": "Enable validation as you type"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts src/server/index.ts --format cjs --no-dts --external vscode",
    "dev": "tsup src/extension.ts src/server/index.ts --format cjs --no-dts --external vscode --watch",
    "package": "vsce package --no-dependencies",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentmd-dev/core": "workspace:*",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@types/vscode": "^1.85.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}