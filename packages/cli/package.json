{
  "name": "@agentmd-dev/cli",
  "version": "0.1.1",
  "description": "AgentMD CLI — validate, score, and run AGENTS.md",
  "type": "module",
  "bin": {
    "agentmd": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iedayan/agentmd.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "agents.md",
    "agents-md",
    "ai-agents",
    "cli",
    "validation"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "homepage": "https://agentmd.online",
  "bugs": {
    "url": "https://github.com/iedayan/agentmd/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/iedayan/agentmd"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm",
    "dev": "tsup src/cli.ts --format esm --watch",
    "test": "pnpm run build && vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentmd-dev/core": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
