{
  "name": "@agentmd-dev/workflows",
  "version": "0.1.0",
  "description": "AgentMD workflow implementations",
  "type": "module",
  "main": "./dist/workflows/index.js",
  "types": "./dist/workflows/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/workflows/index.js",
      "types": "./dist/workflows/index.d.ts"
    },
    "./pr-reviewer": {
      "import": "./dist/workflows/pr-reviewer/index.js",
      "types": "./dist/workflows/pr-reviewer/index.d.ts"
    }
  },
  "files": [
    "dist",
    "pr-reviewer",
    "test-triage"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "demo": "tsx demo/pr-reviewer-demo.ts"
  },
  "dependencies": {
    "@agentmd-dev/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
