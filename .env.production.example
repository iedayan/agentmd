# AgentMD Production Environment Variables Template
# Copy this file to .env.production and fill in the values.
# See docs/LAUNCH_CHECKLIST.md for security recommendations.

# --- Core (Required for Soft Launch) ---
NEXT_PUBLIC_APP_URL=https://agentmd.online
NEXTAUTH_URL=https://agentmd.online
NEXTAUTH_SECRET=                  # Run 'openssl rand -base64 32' to generate
GITHUB_ID=                        # GitHub OAuth Client ID
GITHUB_SECRET=                    # GitHub OAuth Client Secret
DATABASE_URL=                     # Neon Postgres pooled connection URL

# --- Infrastructure (Required for Full Launch) ---
REDIS_URL=                        # Upstash Redis URL (rediss://...)
GITHUB_WEBHOOK_SECRET=            # GitHub App Webhook Signing Secret
S3_BUCKET=agentmd-logs
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Integrations & Monitoring ---
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
SENTRY_DSN=
SLACK_WEBHOOK_URL=                # For production alerts

# --- Worker Configuration ---
AGENTMD_REAL_EXECUTION=1          # Set to 1 to enable real command execution
WORKER_POLL_INTERVAL_MS=5000
