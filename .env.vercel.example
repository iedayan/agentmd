# Vercel Environment Variables - copy to Vercel Dashboard
# Replace placeholders with your values. Generate secrets: openssl rand -base64 32

# --- Required (soft launch) ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=
GITHUB_ID=
GITHUB_SECRET=
DATABASE_URL=

# --- Optional (full launch) ---
REDIS_URL=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
SENTRY_DSN=
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
JIRA_WEBHOOK_URL=
