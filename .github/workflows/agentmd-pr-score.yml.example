# Example: AgentMD score + PR comment
# Posts agent-readiness score to every PR.
# Copy to .github/workflows/agentmd.yml
#
# The default GITHUB_TOKEN can create comments on PRs from the same repo.
name: AgentMD Score

on:
  pull_request:
    branches: [main, master]

jobs:
  score:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: AgentMD score
        id: score
        uses: agentmd/agentmd/.github/actions/agentmd@main
        with:
          command: score
          path: .

      - name: Comment PR with score
        uses: actions/github-script@v7
        if: github.event_name == 'pull_request'
        with:
          script: |
            const score = ${{ steps.score.outputs.score || 0 }};
            const body = `## Agent-readiness score: **${score}/100**

            Is your repo agent-ready? [Get your score](https://agentmd.io) | [Add badge](https://agentmd.io/docs#badge)`;
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body
            });
