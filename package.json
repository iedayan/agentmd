{
  "name": "agentmd",
  "version": "0.1.0",
  "private": true,
  "description": "CI/CD for AI Agents - makes AGENTS.md executable",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @agentmd-dev/core run build",
    "build:cli": "pnpm --filter @agentmd-dev/cli run build",
    "build:sdk": "pnpm --filter @agentmd-dev/sdk run build",
    "build:dashboard": "pnpm --filter @agentmd/dashboard run build",
    "build:vscode": "pnpm --filter @agentmd/vscode run build",
    "dev:dashboard": "pnpm --filter @agentmd/dashboard run dev",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "check": "pnpm -w lint && pnpm -w test && pnpm -w build",
    "lint:fix": "eslint --ext .ts,.tsx . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "agentmd": "node packages/cli/dist/cli.js",
    "migrate": "node deploy/scripts/migrate.js",
    "migrate:rollback": "node deploy/scripts/migrate-rollback.js",
    "migrate:verify": "node deploy/scripts/verify-migrations.js",
    "hooks:install": "git config core.hooksPath .githooks",
    "launch:mvp:check": "node deploy/scripts/mvp-launch-check.mjs --target=production",
    "github:protect:branch": "node deploy/scripts/github-branch-protection.mjs",
    "launch:env:staging": "node deploy/scripts/validate-launch-env.mjs --target=staging",
    "github:config": "node deploy/scripts/github-config.mjs",
    "launch:env:prod": "node deploy/scripts/validate-launch-env.mjs --target=production",
    "terraform:apply": "cd deploy/terraform && terraform apply",
    "terraform:plan": "cd deploy/terraform && terraform plan",
    "terraform:output": "cd deploy/terraform && terraform output -json | node ../scripts/terraform-to-env.mjs"
  },
  "keywords": [
    "agents.md",
    "ai-agents",
    "ci-cd",
    "orchestration"
  ],
  "author": "AgentMD",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.14.2",
  "devDependencies": {
    "eslint": "8.57.1",
    "@typescript-eslint/parser": "^5.60.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "prettier": "^3.0.0"
  }
}
