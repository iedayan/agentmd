# AgentMD Production Environment Template
# Copy to .env and fill in values. Never commit secrets.
#
# Soft launch minimum: DATABASE_URL, NEXTAUTH_*, GITHUB_ID, GITHUB_SECRET, NEXT_PUBLIC_APP_URL
# Full launch: Add REDIS_URL, STRIPE_*, SENTRY_DSN, SLACK_WEBHOOK_URL, S3_*

# === Database (Neon) ===
# Use the Pooled connection string from Neon Console (Connect > Connection string > Pooled)
# Format: postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:pass@host:5432/agentmd?sslmode=require

# === Redis (Upstash) ===
REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# === Storage (S3 / R2) ===
S3_BUCKET=agentmd-logs
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Or R2:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=agentmd-logs

# === Auth ===
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://agentmd.online
GITHUB_ID=
GITHUB_SECRET=

# === GitHub App (webhooks, repo connection) ===
GITHUB_APP_SLUG=agentmd
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=whsec_xxx

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
NEXT_PUBLIC_APP_URL=https://agentmd.online

# === Monitoring ===
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# === Enterprise (Self-Hosted) ===
AGENTMD_LICENSE_KEY=
SAML_ENTITY_ID=
SAML_SSO_URL=
