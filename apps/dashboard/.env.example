NEXT_PUBLIC_APP_URL=http://localhost:3001
# NEXTAUTH_URL=http://localhost:3001  # defaults to NEXT_PUBLIC_APP_URL in dev

# Database (required in production unless AGENTMD_ALLOW_IN_MEMORY=true)
# DATABASE_URL=postgresql://user:pass@host:5432/agentmd?sslmode=require
# AGENTMD_ALLOW_IN_MEMORY=false

# NextAuth (required for dashboard auth)
NEXTAUTH_SECRET=your-secret-at-least-32-chars
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# Queue/Cache (required in production)
# REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# GitHub App (optional - for repo connection via app installation)
# GITHUB_APP_SLUG=agentmd
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=whsec_xxx

# Storage (required in production for execution logs/artifacts)
# S3_BUCKET=agentmd-logs
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Monitoring/alerts
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx  # From Stripe webhook endpoint
